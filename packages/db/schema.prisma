generator client {
  provider = "prisma-kysely"

  output = "./src/generated/kysely"
}

generator zero {
  provider = "prisma-zero"

  output = "./src/generated/zero"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String
  displayName   String
  avatarUrl     String?
  isStaff       Boolean        @default(false)
  githubAccount GitHubAccount?
  sessions      Session[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model GitHubAccount {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubId         Int      @unique
  login            String
  oauthAccessToken String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum SandboxStatus {
  idle
  provisioning
  ready
  pausing
  paused
  resuming
  terminated
  errored
}

enum SessionCommandStatus {
  pending
  processing
  done
  failed
}

model Session {
  id                String           @id @default(uuid())
  userId            Int
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt            String
  e2bSandboxId      String?
  opencodeSessionId String?
  sandboxStatus     SandboxStatus    @default(idle)
  lastActivityAt    DateTime         @default(now())
  todos             Json?
  summary           Json?
  errorMessage      String?
  messages          SessionMessage[]
  commands          SessionCommand[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model SessionCommand {
  id          String               @id @default(uuid())
  sessionId   String
  session     Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        String
  payload     Json
  status      SessionCommandStatus @default(pending)
  error       String?
  createdAt   DateTime             @default(now())
  processedAt DateTime?
  updatedAt   DateTime             @updatedAt

  @@index([sessionId, status, createdAt])
}

model SessionMessage {
  id         String               @id @default(uuid())
  opencodeId String               @unique
  sessionId  String
  session    Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       String
  parts      SessionMessagePart[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
}

model SessionMessagePart {
  id         String         @id @default(uuid())
  opencodeId String         @unique
  messageId  String
  message    SessionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type       String
  data       Json
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}
