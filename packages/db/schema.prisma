generator client {
  provider = "prisma-kysely"

  output = "./src/generated/kysely"
}

generator zero {
  provider = "prisma-zero"

  output = "./src/generated/zero"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int            @id @default(autoincrement())
  email         String
  displayName   String
  avatarUrl     String?
  isStaff       Boolean        @default(false)
  githubAccount GitHubAccount?
  githubRepos   GitHubRepo[]
  kanbanCards   KanbanCard[]
  cardRuns      CardRun[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model GitHubAccount {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubId         Int      @unique
  login            String
  oauthAccessToken String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GitHubRepo {
  id             Int          @id @default(autoincrement())
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubRepoId   Int
  name           String
  fullName       String
  ownerLogin     String
  ownerAvatarUrl String?
  description    String?
  htmlUrl        String
  isPrivate      Boolean
  defaultBranch  String
  kanbanCards    KanbanCard[]
  cardRuns       CardRun[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, githubRepoId])
}

model KanbanCard {
  id        String     @id @db.Uuid
  repoId    Int
  repo      GitHubRepo @relation(fields: [repoId], references: [id], onDelete: Cascade)
  userId    Int
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  number    Int
  title     String
  columnId  String
  sortOrder String
  cardRuns  CardRun[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([repoId, number])
}

enum CardRunStatus {
  pending
  running
  completed
  failed
}

model CardRun {
  id         String        @id @db.Uuid
  cardId     String        @db.Uuid
  card       KanbanCard    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  repoId     Int
  repo       GitHubRepo    @relation(fields: [repoId], references: [id], onDelete: Cascade)
  userId     Int
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     CardRunStatus @default(pending)
  branchName String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}
