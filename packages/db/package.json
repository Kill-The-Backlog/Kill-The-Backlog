{
  "name": "@ktb/db",
  "private": true,
  "type": "module",
  "exports": {
    "./client": {
      "types": "./src/client.ts",
      "default": "./build/client.js"
    },
    "./types": {
      "types": "./src/generated/kysely/types.ts",
      "default": "./build/generated/kysely/types.js"
    },
    "./zero": {
      "types": "./src/generated/zero/schema.ts",
      "default": "./build/generated/zero/schema.js"
    },
    "./json-types": {
      "types": "./src/json-types.ts",
      "default": "./build/json-types.js"
    },
    "./kysely-types": {
      "types": "./src/kysely-types.ts",
      "default": "./build/kysely-types.js"
    },
    "./kysely-helpers": {
      "types": "./src/kysely-helpers.ts",
      "default": "./build/kysely-helpers.js"
    }
  },
  "files": [
    "build",
    "schema.prisma",
    "migrations",
    "*.config.ts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@ktb/shared": "workspace:*",
    "@rocicorp/zero": "^1.4.0",
    "kysely": "^0.29.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "prisma-cli": "^1.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ktb/eslint-configs": "workspace:*",
    "@ktb/ts-configs": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.3.0",
    "prisma-kysely": "^3.1.0",
    "prisma-zero": "^0.1.3",
    "typescript": "^6.0.3"
  }
}
