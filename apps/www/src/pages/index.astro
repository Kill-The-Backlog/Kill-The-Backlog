---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main
    class="flex flex-1 items-center justify-center px-6 pt-20 pb-16 md:pt-24 md:pb-20"
  >
    <div class="max-w-3xl text-center">
      <!-- Headline -->
      <h1
        class="font-display text-text text-5xl tracking-tight md:text-6xl lg:text-7xl"
      >
        <span>Ship products, not backlogs.</span>
        <span class="block">
          Coming
          <span
            class="from-accent bg-linear-to-r to-purple-400 bg-clip-text text-transparent"
          >
            soon.
          </span>
        </span>
      </h1>
    </div>
  </main>
</Layout>
