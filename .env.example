# ──────────────────────────────────────────────────────────────
# Kill The Backlog – Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values below.
#
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── GitHub OAuth (required) ──────────────────────────────────
# Create a GitHub OAuth App at https://github.com/settings/developers
# and set the callback URL to http://localhost:3000/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# ── AI providers (required) ──────────────────────────────────
# Agents run inside E2B cloud sandboxes and use Anthropic for
# coding. Both services have free tiers.
ANTHROPIC_API_KEY=
E2B_API_KEY=

# ── Session ──────────────────────────────────────────────────
# Random string for cookie encryption. The default is fine for
# local use; set a strong random value in production.
SESSION_SECRET=local-development-secret
