# ──────────────────────────────────────────────────────────────
# Kill The Backlog – Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values below.
#
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# - GitHub OAuth -
# Create a GitHub OAuth App at https://github.com/settings/developers.
# The callback URL depends on how you're running the app:
#   - Docker Quick Start:  http://localhost:3000/auth/github/callback
#   - Devbox development:  https://ktb.localhost/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# - AI provider -
# Agents use Anthropic as the coding model. Free tier available.
ANTHROPIC_API_KEY=

# - E2B sandbox -
# Agents run inside E2B cloud sandboxes. Free tier available.
E2B_API_KEY=

# Name of the E2B template to launch sandboxes from. `e2b-template-dev` is
# produced by `pnpm tools:e2b-template e2b:build:dev` (see tools/e2b-template).
E2B_TEMPLATE_NAME=e2b-template-dev

# - Session -
# Random string for cookie encryption. The default is fine for local use;
# in production generate a strong value, e.g. `openssl rand -base64 32`.
SESSION_SECRET=local-development-secret
