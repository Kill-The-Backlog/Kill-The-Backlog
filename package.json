{
  "name": "@ktb/root",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "apps:main": "pnpm --filter \"@ktb/main\"",
    "apps:www": "pnpm --filter \"@ktb/www\"",
    "clean:node_modules": "find . -name node_modules -type d -prune -exec rm -rf '{}' +",
    "packages:db": "pnpm --filter \"@ktb/db\"",
    "packages:shared": "pnpm --filter \"@ktb/shared\"",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "prisma": "pnpm --filter \"@ktb/db\" exec prisma",
    "shadcn": "pnpm dlx shadcn@latest",
    "tools:e2b-template": "pnpm --filter \"@ktb/e2b-template\""
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "syncpack": "^15.0.0",
    "turbo": "^2.9.12"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@rocicorp/zero-sqlite3",
      "@tailwindcss/oxide",
      "core-js",
      "esbuild",
      "fsevents",
      "msgpackr-extract",
      "msw",
      "prisma",
      "protobufjs",
      "sharp"
    ]
  }
}
