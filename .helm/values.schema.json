{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "baseDomain",
    "clusterIssuerName",
    "mainEnvVars",
    "wwwBucketHostname"
  ],
  "properties": {
    "baseDomain": {
      "type": "string",
      "minLength": 1
    },
    "clusterIssuerName": {
      "type": "string",
      "minLength": 1
    },
    "mainEnvVars": {
      "type": "object",
      "minProperties": 1
    },
    "wwwBucketHostname": {
      "type": "string",
      "minLength": 1
    }
  }
}
